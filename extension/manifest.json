{
  "manifest_version": 3,
  "name": "Flow Harvester (spike)",
  "version": "2.0.0",
  "version_name": "2.0.0-spike.1",
  "description": "Flow Harvester V2 Chrome extension — spike build. Connects to Co-Pilot at ws://127.0.0.1:8080.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "scripting",
    "tabs",
    "downloads",
    "alarms",
    "notifications",
    "management",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://labs.google/fx/tools/flow/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "incognito": "not_allowed"
}
